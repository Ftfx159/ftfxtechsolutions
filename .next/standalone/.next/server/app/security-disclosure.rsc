8:["$","section",null,{"className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Responsible Vulnerability Disclosure"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"If you believe you have discovered a security vulnerability in our website, IT infrastructure, or client portals, we strongly encourage you to report it to us immediately. We request that you:"}],["$","ul",null,{"className":"legal-module__8113wq__list","children":[["$","li",null,{"children":"Do not exploit the vulnerability to view, delete, alter, or otherwise access data that does not belong to you."}],["$","li",null,{"children":"Do not conduct Denial of Service (DoS/DDoS) attacks, social engineering, spamming, or phishing attacks against our employees or clients."}],["$","li",null,{"children":"Provide us a reasonable amount of time to resolve the issue before disclosing it publicly."}],["$","li",null,{"children":["Submit your detailed findings, including steps to reproduce the vulnerability, to ",["$","strong",null,{"children":"Support@ftfxtechsolutions.com"}],"."]}]]}]]}]
9:["$","section",null,{"className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Our Response"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"Upon receiving your report, our engineering team will acknowledge receipt within 48 hours. We will investigate the issue and provide an estimated timeline for a patch. We commit to not pursuing legal action against security researchers who comply with this Responsible Disclosure Policy and act in good faith."}]]}]
