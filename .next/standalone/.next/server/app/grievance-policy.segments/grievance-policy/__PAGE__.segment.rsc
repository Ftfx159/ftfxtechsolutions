0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"legal-module__8113wq__pageContainer","children":[["$","$L2",null,{}],["$","section",null,{"className":"legal-module__8113wq__hero","children":[["$","h1",null,{"className":"legal-module__8113wq__heroTitle","children":"Grievance Redressal Policy"}],["$","p",null,{"className":"legal-module__8113wq__heroSubtitle","children":["Last Updated: ","24/7/2026"]}]]}],["$","div",null,{"className":"legal-module__8113wq__contentContainer","children":["$","article",null,{"className":"legal-module__8113wq__mainContent","style":{"flex":1,"maxWidth":"800px","margin":"0 auto"},"children":[["$","section",null,{"className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Objective"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"FTFX TECH SOLUTIONS (OPC) PRIVATE LIMITED believes in providing a seamless and premium experience to all our customers. The objective of this Grievance Redressal Policy is to provide a framework for resolving customer complaints and grievances in a fair, transparent, and timely manner, in compliance with the Consumer Protection (E-Commerce) Rules, 2020 and the Information Technology Act, 2000."}]]}],["$","section",null,{"className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"How to Raise a Grievance"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"If you have a grievance regarding our services, billing, or data privacy, you can register your complaint through the following channels:"}],["$","ul",null,{"className":"legal-module__8113wq__list","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Email:"}]," Send an email to our dedicated Grievance Officer at Support@ftfxtechsolutions.com with the subject line \"Grievance / Complaint - [Your Name]\"."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Phone:"}]," Call our support desk at 08595691335 during standard business hours (IST)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Written Letter:"}]," Send a formal letter to: Grievance Officer, FTFX TECH SOLUTIONS (OPC) PRIVATE LIMITED, Shop No. 159, Anand Garden, Near Railway Station, Gurgaon, Haryana 122001."]}]]}]]}],["$","section",null,{"className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Resolution Process and Timelines"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"Upon receiving a grievance, we adhere to the following timelines:"}],["$","ul",null,{"className":"legal-module__8113wq__list","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Acknowledgment:"}]," We will acknowledge the receipt of your grievance within 48 hours and provide you with a ticket reference number."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Resolution:"}]," We aim to resolve all grievances within one (1) month from the date of receipt, in accordance with applicable Indian laws."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Escalation:"}]," If the resolution provided is unsatisfactory, you may request an escalation to the senior management team for further review."]}]]}]]}]]}]}],["$","$L3",null,{}]]}],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/3izcsvynze-sw.css","precedence":"next"}],["$","script","script-0",{"src":"/_next/static/chunks/3dzb2wvsg6dxw.js","async":true}]],["$","$L4",null,{"children":["$","$5",null,{"name":"Next.MetadataOutlet","children":"$@6"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"6JxBV_Py11TqinohXGaBP"}
