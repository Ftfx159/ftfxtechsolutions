ldren":[["$","strong",null,{"children":"Data Recovery:"}]," We operate predominantly on a \"No Data, No Fee\" policy for standard recoveries. If we are unable to recover the requested target data after diagnostic approval, you will not be charged the recovery fee. If payment was taken as an advance and recovery fails, the advance (minus any agreed non-refundable diagnostic/donor parts fees) will be refunded."]}],["$","p",null,{"className":"legal-module__8113wq__text","children":[["$","strong",null,{"children":"IT Support & Website Design:"}]," Refunds for IT services and development projects are evaluated on a milestone basis. If you are dissatisfied with a delivered milestone, you must notify us within 7 days. Refunds for completed and approved milestones are not generally permitted."]}]]}],["$","section",null,{"id":"non-refundable","className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Non-Refundable Services"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"The following items and services are strictly non-refundable:"}],["$","ul",null,{"className":"legal-module__8113wq__list","children":[["$","li",null,{"children":"Emergency or Expedited service fees (as these cover the cost of prioritizing your case, regardless of outcome)."}],["$","li",null,{"children":"Fees for donor parts explicitly purchased specifically for your data recovery case (which you agreed to prior to purchase)."}],["$","li",null,{"children":"Domain registration fees, server hosting costs, or third-party software licenses purchased on your behalf."}],["$","li",null,{"children":"Services that have been fully delivered, accepted, and signed off by the client."}]]}]]}],["$","section",null,{"id":"cancellation-process","className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Cancellation Process"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"If you wish to cancel an ongoing service or project, you must submit a cancellation request in writing to Support@ftfxtechsolutions.com."}],"$L3","$L4"]}],"$L5"]}]]}],"$L6"]}],["$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"6JxBV_Py11TqinohXGaBP"}
3:["$","p",null,{"className":"legal-module__8113wq__text","children":[["$","strong",null,{"children":"Data Recovery:"}]," You may cancel a recovery request at any time before the recovery attempt begins. If you cancel after engineering work has commenced, you may be liable for labor costs incurred up to the point of cancellation."]}]
4:["$","p",null,{"className":"legal-module__8113wq__text","children":[["$","strong",null,{"children":"Website Design:"}]," Cancellation of a web development project will result in a halt of all work. The client will be billed for the pro-rated hours completed up to the date of cancellation. Any advance deposits exceeding the value of work completed will be refunded."]}]
5:["$","section",null,{"id":"processing-timelines","className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Processing Timelines"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"Once a refund request is approved by our billing department, it will be processed within 5-7 business days."}],["$","p",null,{"className":"legal-module__8113wq__text","children":"Refunds will be credited back to the original method of payment (e.g., Credit Card, UPI, Bank Transfer). Depending on your bank or payment provider, it may take an additional 3-5 business days for the funds to reflect in your account."}]]}]
