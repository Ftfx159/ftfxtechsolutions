3:["$","p",null,{"className":"legal-module__8113wq__text","children":"We may use cookies and similar tracking technologies (like web beacons and pixels) to access or store information. Specific information about how we use such technologies and how you can refuse certain cookies is set out in our Cookie Notice."}]
4:["$","p",null,{"className":"legal-module__8113wq__text","children":"Cookies help us understand how the site is being used and improve your user experience. You can set your browser to refuse all or some browser cookies, or to alert you when websites set or access cookies."}]
5:["$","section",null,{"id":"data-security","className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Data Security"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"We have implemented appropriate technical and organizational security measures designed to protect the security of any personal information we process. Our physical, electronic, and managerial procedures safeguard and secure the information we collect online."}],["$","p",null,{"className":"legal-module__8113wq__text","children":"Especially regarding Data Recovery services, all recovered data is stored on encrypted, offline staging servers within our secure facility in Gurgaon, India, and is permanently wiped in accordance with strict data sanitization standards after successful delivery to the client."}]]}]
6:["$","section",null,{"id":"third-party-services","className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Third-Party Services"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"We only share information with your consent, to comply with laws, to provide you with services, to protect your rights, or to fulfill business obligations. We may process or share your data that we hold based on the following legal basis:"}],["$","ul",null,{"className":"legal-module__8113wq__list","children":[["$","li",null,{"children":"Consent: We may process your data if you have given us specific consent to use your personal information for a specific purpose."}],["$","li",null,{"children":"Legitimate Interests: We may process your data when it is reasonably necessary to achieve our legitimate business interests."}],["$","li",null,{"children":"Performance of a Contract: Where we have entered into a contract with you, we may process your personal information to fulfill the terms of our contract."}]]}],["$","p",null,{"className":"legal-module__8113wq__text","children":"We do not sell, rent, or trade your personal information with third parties for their promotional purposes."}]]}]
7:["$","section",null,{"id":"user-rights","className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"User Rights"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"Under Indian law, you have certain rights regarding your personal information. These include the right to review the information you have provided and request that any inaccurate or deficient information be corrected or amended."}],["$","p",null,{"className":"legal-module__8113wq__text","children":"If you would at any time like to review or change the information in your account or terminate your account, you can contact us using the contact information provided below. Upon your request to terminate your account, we will deactivate or delete your account and information from our active databases."}]]}]
8:["$","section",null,{"id":"contact-information","className":"legal-module__8113wq__section","children":[["$","h2",null,{"className":"legal-module__8113wq__sectionTitle","children":"Contact Information"}],["$","p",null,{"className":"legal-module__8113wq__text","children":"If you have questions or comments about this policy, or if you have a grievance with respect to the processing of your personal information, you may contact our Grievance Officer:"}],["$","p",null,{"className":"legal-module__8113wq__text","children":[["$","strong",null,{"children":"FTFX TECH SOLUTIONS (OPC) PRIVATE LIMITED"}],["$","br",null,{}],"Shop No. 159, Anand Garden,",["$","br",null,{}],"Near Railway Station,",["$","br",null,{}],"Gurgaon, Haryana 122001, India",["$","br",null,{}],"Email: Support@ftfxtechsolutions.com",["$","br",null,{}],"Phone: 08595691335"]}]]}]
