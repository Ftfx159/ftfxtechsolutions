{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ],
      "regex": "^(?:/(.*))(?:/)?$"
    }
  ],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/accessibility",
      "regex": "^/accessibility(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/accessibility(?:/)?$"
    },
    {
      "page": "/compliance",
      "regex": "^/compliance(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/compliance(?:/)?$"
    },
    {
      "page": "/copyright-policy",
      "regex": "^/copyright\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/copyright\\-policy(?:/)?$"
    },
    {
      "page": "/data-recovery",
      "regex": "^/data\\-recovery(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/data\\-recovery(?:/)?$"
    },
    {
      "page": "/free-evaluation",
      "regex": "^/free\\-evaluation(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/free\\-evaluation(?:/)?$"
    },
    {
      "page": "/grievance-policy",
      "regex": "^/grievance\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/grievance\\-policy(?:/)?$"
    },
    {
      "page": "/icon.png",
      "regex": "^/icon\\.png(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.png(?:/)?$"
    },
    {
      "page": "/privacy-policy",
      "regex": "^/privacy\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy(?:/)?$"
    },
    {
      "page": "/refund-policy",
      "regex": "^/refund\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/refund\\-policy(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/security-disclosure",
      "regex": "^/security\\-disclosure(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/security\\-disclosure(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/terms-of-service",
      "regex": "^/terms\\-of\\-service(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms\\-of\\-service(?:/)?$"
    },
    {
      "page": "/troubleshoot",
      "regex": "^/troubleshoot(?:/)?$",
      "routeKeys": {},
